// no-distraction — turn VS Code into a quiet text editor.
// A focused fragment: ONLY keys that suppress IntelliSense, suggestions,
// validation squiggles, and UI clutter. No theme, font, git, or AI/personal
// prefs — keep those in your own settings.json. Copy the keys you want.
{
  // --- Window / UI chrome ---
  "window.commandCenter": false,
  "window.menuBarVisibility": "toggle",
  "workbench.startupEditor": "none",         // skip the Welcome tab on launch
  "workbench.secondarySideBar.defaultVisibility": "hidden",  // keep the right-hand Chat / Agent-Sessions panel closed (VS Code 1.104+ shows it by default; toggle: Cmd/Ctrl+Alt+B)
  "breadcrumbs.enabled": false,
  "editor.minimap.enabled": false,
  "markdown.preview.markEditorSelection": false,
  "workbench.colorCustomizations": {
    "editorHint.foreground": "#00000000",    // hide hint squiggles (e.g. Python pyproject.toml)
    "editorHint.border": "#00000000"
  },

  // --- Editor noise / highlights ---
  "editor.occurrencesHighlight": "off",      // no boxes around the word under cursor
  "editor.renderLineHighlight": "none",      // no highlight on the current line
  "editor.formatOnSave": false,
  "editor.formatOnPaste": false,
  "editor.formatOnType": false,

  // --- IntelliSense / suggestions (off) ---
  // "onlySnippets", not "off": snippet expansion only fires when you type a
  // prefix you defined and press Tab — nothing appears unbidden, so it isn't a
  // distraction, and it keeps the separator-line snippets in vs-code.md working.
  "editor.tabCompletion": "onlySnippets",
  "editor.inlineSuggest.enabled": false,     // no ghost-text inline suggestions (Copilot etc.)
  "editor.quickSuggestions": {
    "comments": "off",
    "strings": "off",
    "other": "off"
  },
  "editor.suggestOnTriggerCharacters": false,
  "editor.acceptSuggestionOnEnter": "off",
  "editor.wordBasedSuggestions": "off",
  "editor.parameterHints.enabled": false,
  "editor.hover.enabled": "off",             // enum, no longer boolean: "on"|"off"|"onKeyboardModifier"
  "problems.decorations.enabled": false,
  "editor.renderValidationDecorations": "off",

  // --- Code actions / lenses (off) ---
  "editor.lightbulb.enabled": "off",
  "editor.codeLens": false,

  // --- Source-control decorations (off) ---
  "scm.diffDecorations": "none",
  "scm.countBadge": "off",                   // hide the +N badge on the SCM icon

  // --- Validation squiggles (off) ---
  "typescript.validate.enable": false,
  "javascript.validate.enable": false,
  "css.validate": false,
  "html.validate.scripts": false,
  "html.validate.styles": false,
  "json.validate.enable": false,
  "python.analysis.typeCheckingMode": "off",
  "python.analysis.ignore": ["**"],          // silence Pylance diagnostics entirely
  "python.analysis.autoImportCompletions": false
}
